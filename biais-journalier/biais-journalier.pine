//@version=6
// =============================================================================
//  Biais Journalier — S&P 500 / Nasdaq / Or / Dow Jones
// -----------------------------------------------------------------------------
//  Affiche, dans un tableau, un biais HAUSSIER / NEUTRE / BAISSIER pour la
//  séance en cours sur 4 actifs, quel que soit le graphique sur lequel
//  l'indicateur est appliqué.
//
//  Le biais est calculé via un SCORE DE CONFLUENCE (de -6 à +6) basé sur
//  6 signaux mesurés sur l'unité de temps journalière (D) :
//    1) Cours au-dessus / en-dessous de l'EMA rapide
//    2) Cours au-dessus / en-dessous de l'EMA lente
//    3) Cours au-dessus / en-dessous de la clôture de la veille
//    4) Cours au-dessus / en-dessous de l'ouverture du jour
//    5) Momentum RSI (au-dessus du seuil haussier / sous le seuil baissier)
//    6) Cassure du range de la veille (au-dessus du plus haut / sous le plus bas)
//
//  Classement final :
//    score >= +seuil  -> HAUSSIER
//    score <= -seuil  -> BAISSIER
//    sinon            -> NEUTRE
//
//  NOTE : pour la séance en cours, le biais évolue au fil de la journée
//  (« repaint » volontaire) ; il se fige à la clôture journalière.
//
//  AVERTISSEMENT : outil d'aide à la décision, ce n'est PAS un conseil en
//  investissement. À utiliser à vos propres risques.
// =============================================================================
indicator("Biais Journalier — Indices & Or", shorttitle="Biais Journalier", overlay = true)

// ----------------------------------------------------------------------------
//  ENTRÉES — Symboles suivis
// ----------------------------------------------------------------------------
grpSym = "Symboles suivis"
symSPX = input.symbol("SP:SPX",      "S&P 500",   group = grpSym)
symNDX = input.symbol("NASDAQ:NDX",  "Nasdaq",    group = grpSym)
symGLD = input.symbol("TVC:GOLD",    "Or",        group = grpSym)
symDJI = input.symbol("DJ:DJI",      "Dow Jones", group = grpSym)

// ----------------------------------------------------------------------------
//  ENTRÉES — Calcul du biais
// ----------------------------------------------------------------------------
grpCalc    = "Calcul du biais"
biasTf     = input.timeframe("D", "Unité de temps du biais", group = grpCalc)
emaFastLen = input.int(20, "EMA rapide",            minval = 1,              group = grpCalc)
emaSlowLen = input.int(50, "EMA lente",             minval = 1,              group = grpCalc)
rsiLen     = input.int(14, "Longueur RSI",          minval = 1,              group = grpCalc)
rsiBull    = input.int(55, "Seuil RSI haussier",    minval = 50, maxval = 100, group = grpCalc)
rsiBear    = input.int(45, "Seuil RSI baissier",    minval = 0,  maxval = 50,  group = grpCalc)
biasTh     = input.int(2,  "Seuil |score| pour valider un biais", minval = 1, maxval = 6, group = grpCalc)

// ----------------------------------------------------------------------------
//  ENTRÉES — Affichage
// ----------------------------------------------------------------------------
grpDisp   = "Affichage"
tblPosStr = input.string("Haut droite", "Position du tableau", options = ["Haut gauche", "Haut centre", "Haut droite", "Bas gauche", "Bas centre", "Bas droite"], group = grpDisp)
txtSzStr  = input.string("Normale", "Taille du texte", options = ["Petite", "Normale", "Grande"], group = grpDisp)
showChg   = input.bool(true, "Afficher la variation %", group = grpDisp)
showScore = input.bool(true, "Afficher le score",       group = grpDisp)

// ----------------------------------------------------------------------------
//  FONCTIONS — calcul
// ----------------------------------------------------------------------------
// Calcule, sur l'unité de temps demandée, le score de confluence (-6..+6)
// et la variation % de la séance.
f_data() =>
    emaF = ta.ema(close, emaFastLen)
    emaS = ta.ema(close, emaSlowLen)
    rsiV = ta.rsi(close, rsiLen)
    score = 0
    score += close > emaF     ? 1 : -1                                   // 1) EMA rapide
    score += close > emaS     ? 1 : -1                                   // 2) EMA lente
    score += close > close[1] ? 1 : -1                                   // 3) clôture veille
    score += close > open     ? 1 : -1                                   // 4) ouverture du jour
    score += rsiV > rsiBull   ? 1 : (rsiV < rsiBear ? -1 : 0)            // 5) momentum RSI
    score += close > high[1]  ? 1 : (close < low[1]  ? -1 : 0)           // 6) cassure range veille
    chg = na(close[1]) ? na : (close - close[1]) / close[1] * 100.0
    [score, chg]

// Libellé du biais à partir du score
f_label(s) =>
    s >= biasTh ? "HAUSSIER" : s <= -biasTh ? "BAISSIER" : "NEUTRE"

// Couleur de fond associée au biais
f_color(s) =>
    s >= biasTh ? color.new(#26a69a, 0) : s <= -biasTh ? color.new(#ef5350, 0) : color.new(#787b86, 0)

// Variation % formatée avec signe
f_chg(c) =>
    na(c) ? "—" : (c >= 0 ? "+" : "") + str.tostring(c, "0.00") + " %"

// ----------------------------------------------------------------------------
//  FONCTIONS — mappage des entrées d'affichage
// ----------------------------------------------------------------------------
f_pos(s) =>
    s == "Haut gauche"  ? position.top_left      :
     s == "Haut centre" ? position.top_center    :
     s == "Haut droite" ? position.top_right     :
     s == "Bas gauche"  ? position.bottom_left   :
     s == "Bas centre"  ? position.bottom_center :
     position.bottom_right

f_size(s) =>
    s == "Petite" ? size.small : s == "Grande" ? size.large : size.normal

// ----------------------------------------------------------------------------
//  RÉCUPÉRATION DES DONNÉES (multi-symboles)
// ----------------------------------------------------------------------------
[scSPX, chSPX] = request.security(symSPX, biasTf, f_data())
[scNDX, chNDX] = request.security(symNDX, biasTf, f_data())
[scGLD, chGLD] = request.security(symGLD, biasTf, f_data())
[scDJI, chDJI] = request.security(symDJI, biasTf, f_data())

// ----------------------------------------------------------------------------
//  CONSTRUCTION DU TABLEAU
// ----------------------------------------------------------------------------
ts      = f_size(txtSzStr)
bgHead  = color.new(#1e222d, 0)
bgCell  = color.new(#131722, 15)
colUp   = color.new(#26a69a, 0)
colDn   = color.new(#ef5350, 0)
colTxt  = color.new(color.white, 0)

// Indices de colonnes (dynamiques selon les options d'affichage)
cVar   = 1
cScore = 1 + (showChg ? 1 : 0)
cBias  = 1 + (showChg ? 1 : 0) + (showScore ? 1 : 0)
nCols  = cBias + 1

var table tbl = table.new(f_pos(tblPosStr), nCols, 5, border_width = 1, border_color = color.new(#363a45, 0))

// Écrit une ligne d'actif dans le tableau
f_row(r, nm, sc, ch) =>
    table.cell(tbl, 0, r, nm, text_color = colTxt, text_halign = text.align_left, text_size = ts, bgcolor = bgHead)
    if showChg
        table.cell(tbl, cVar, r, f_chg(ch), text_color = (na(ch) ? colTxt : (ch >= 0 ? colUp : colDn)), text_size = ts, bgcolor = bgCell)
    if showScore
        table.cell(tbl, cScore, r, (sc >= 0 ? "+" : "") + str.tostring(sc), text_color = colTxt, text_size = ts, bgcolor = bgCell)
    table.cell(tbl, cBias, r, f_label(sc), text_color = colTxt, text_size = ts, bgcolor = f_color(sc))

if barstate.islast
    // En-tête
    table.cell(tbl, 0, 0, "Biais " + biasTf, text_color = colTxt, text_halign = text.align_left, text_size = ts, bgcolor = bgHead)
    if showChg
        table.cell(tbl, cVar, 0, "Var %", text_color = colTxt, text_size = ts, bgcolor = bgHead)
    if showScore
        table.cell(tbl, cScore, 0, "Score", text_color = colTxt, text_size = ts, bgcolor = bgHead)
    table.cell(tbl, cBias, 0, "Biais", text_color = colTxt, text_size = ts, bgcolor = bgHead)

    // Lignes des actifs
    f_row(1, "S&P 500",   scSPX, chSPX)
    f_row(2, "Nasdaq",    scNDX, chNDX)
    f_row(3, "Or",        scGLD, chGLD)
    f_row(4, "Dow Jones", scDJI, chDJI)

// ----------------------------------------------------------------------------
//  ALERTES — passage en biais haussier / baissier
// ----------------------------------------------------------------------------
bullSPX = scSPX >= biasTh
bearSPX = scSPX <= -biasTh
bullNDX = scNDX >= biasTh
bearNDX = scNDX <= -biasTh
bullGLD = scGLD >= biasTh
bearGLD = scGLD <= -biasTh
bullDJI = scDJI >= biasTh
bearDJI = scDJI <= -biasTh

alertcondition(bullSPX and not bullSPX[1], "S&P 500 — Biais HAUSSIER",  "S&P 500 : passage en biais HAUSSIER")
alertcondition(bearSPX and not bearSPX[1], "S&P 500 — Biais BAISSIER",  "S&P 500 : passage en biais BAISSIER")
alertcondition(bullNDX and not bullNDX[1], "Nasdaq — Biais HAUSSIER",   "Nasdaq : passage en biais HAUSSIER")
alertcondition(bearNDX and not bearNDX[1], "Nasdaq — Biais BAISSIER",   "Nasdaq : passage en biais BAISSIER")
alertcondition(bullGLD and not bullGLD[1], "Or — Biais HAUSSIER",       "Or : passage en biais HAUSSIER")
alertcondition(bearGLD and not bearGLD[1], "Or — Biais BAISSIER",       "Or : passage en biais BAISSIER")
alertcondition(bullDJI and not bullDJI[1], "Dow Jones — Biais HAUSSIER", "Dow Jones : passage en biais HAUSSIER")
alertcondition(bearDJI and not bearDJI[1], "Dow Jones — Biais BAISSIER", "Dow Jones : passage en biais BAISSIER")
